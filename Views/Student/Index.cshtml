@model IEnumerable<Day1_Workshop.Models.StudentModel>

@{
    ViewData["Title"] = "Student List";
}

<h2 class="text-center mt-3">Student List</h2>

<div class="container mt-4">

    <div class="mb-3 text-end">
        <a asp-action="Add" class="btn btn-success">Add New Student</a>
    </div>

    <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Branch</th>
                <th>Email</th>
                <th>DOB</th>
                <th>City</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.student_id</td>
                        <td>@item.student_name</td>
                        <td>@item.studentbrach</td>
                        <td>@item.student_email</td>
                        <td>@item.DOB.ToString("dd-MM-yyyy")</td>
                        <td>@item.city</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.student_id" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.student_id" class="btn btn-danger btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-danger">
                        No Records Found
                    </td>
                </tr>
            }

        </tbody>
    </table>

</div>